# Copy to .env on the containers VM; never commit the real .env file.
TZ=America/New_York
PUID=1000
PGID=1000

# Internal/LAN phase. Change to the canonical HTTPS hostname only when the
# separately approval-gated Cloudflare route is ready.
NTFY_BASE_URL=http://192.168.5.252:8093

# Direct-LAN default. Do not enable merely because Cloudflare Tunnel exists;
# first constrain which proxy addresses/headers are trusted.
NTFY_BEHIND_PROXY=false
