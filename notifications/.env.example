# Copy to .env on the containers VM; never commit the real .env file.
TZ=America/New_York
PUID=1000
PGID=1000

# Canonical public HTTPS URL. The direct LAN origin remains available at
# http://192.168.5.252:8093 for local publishers and health checks.
NTFY_BASE_URL=https://notify.walshit.com

# Required by the native iOS app for reliable instant notifications from a
# self-hosted server. ntfy.sh relays the APNS wake-up/poll request; the phone
# retrieves message content from NTFY_BASE_URL.
NTFY_UPSTREAM_BASE_URL=https://ntfy.sh

# Keep false while the origin remains directly reachable on the LAN. Enabling
# forwarded-header trust requires explicit trusted-proxy restrictions first.
NTFY_BEHIND_PROXY=false

# Non-secret ntfy-to-Discord bridge settings. The subscriber token and Discord
# webhook URL belong in discord-bridge/.env, never in this file.
BRIDGE_NTFY_URL=http://ntfy
BRIDGE_STATE_MAX_AGE_SECONDS=180
BRIDGE_SUBSCRIBE_TIMEOUT_SECONDS=75
BRIDGE_RECONNECT_MAX_SECONDS=30
BRIDGE_DISCORD_TIMEOUT_SECONDS=15
BRIDGE_DISCORD_MAX_ATTEMPTS=5
BRIDGE_RETRY_MAX_SECONDS=30
