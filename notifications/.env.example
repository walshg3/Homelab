# Copy to .env on the containers VM; never commit the real .env file.
TZ=America/New_York
PUID=1000
PGID=1000

# Canonical public HTTPS URL. The direct LAN origin remains available at
# http://192.168.5.252:8093 for local publishers and health checks.
NTFY_BASE_URL=https://notify.walshit.com

# Keep false while the origin remains directly reachable on the LAN. Enabling
# forwarded-header trust requires explicit trusted-proxy restrictions first.
NTFY_BEHIND_PROXY=false
