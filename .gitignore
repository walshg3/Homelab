# Ignore everything by default
*

# Recursively allow directories so we can find whitelisted files inside them
!*/

# Whitelist files we want everywhere
!compose.yaml
!compose.yml
!.env.example
!.gitignore

# Keep live runtime, data, dependency, and secret paths opaque
**/.env
**/node_modules/
**/volumes/
**/pgdata/
**/data/
**/cache/
**/.cache/
**/downloads/

# Keep the nested Unpoller checkout independent from this repository
/unpoller-unifi/

# Whitelist specific Kometa config files
!kometa/config/overlay_movies.yml
!kometa/config/overlay_tv.yml

# Whitelist specific Kometa config folders
!kometa/config/overlays/
!kometa/config/overlays/**
!kometa/config/fonts/
!kometa/config/fonts/**

# Whitelist documentation
!README.md

# Whitelist the reviewed ntfy-to-Discord bridge source and tests. Runtime
# secrets and state remain covered by the .env and data exclusions above.
!notifications/discord-bridge/
!notifications/discord-bridge/bridge.py
!notifications/discord-bridge/test_bridge.py

# Whitelist the independent public ntfy health watchdog and tests. Its
# channel-scoped Discord webhook and runtime state remain outside Git.
!notifications/ntfy-watchdog/
!notifications/ntfy-watchdog/ntfy_watchdog.py
!notifications/ntfy-watchdog/test_ntfy_watchdog.py
!notifications/ntfy-watchdog/README.md
!notifications/ntfy-watchdog/.env.example
!notifications/ntfy-watchdog/cron-job.json

# Generated and local-only Kometa poster assets
/kometa/config/overlays/temp.jpg
/kometa/config/overlays/Movies-Sand-Hills Original Posters/
/kometa/config/overlays/TV-Sand-Hills Original Posters/

# Whitelist the reviewed Hugo content prototype: source, tests, and its
# isolated runtime config. The legacy walshit-landing/site/, Dockerfile,
# nginx.conf, and compose.yaml remain covered by the existing whitelist
# entries above and are untouched by this prototype.
!walshit-landing/hugo/
!walshit-landing/hugo/**
!walshit-landing/tests/
!walshit-landing/tests/**
!walshit-landing/Dockerfile.hugo
!walshit-landing/Dockerfile.hugo.dockerignore
!walshit-landing/nginx.hugo.conf
!walshit-landing/security-headers.conf
!walshit-landing/compose.hugo.yaml
!walshit-landing/scripts/
!walshit-landing/scripts/**

# Keep Hugo build output and Python bytecode caches out of Git even
# though the directories above are whitelisted.
walshit-landing/hugo/public/
walshit-landing/hugo/.hugo_build.lock
walshit-landing/hugo/hugo_stats.json
walshit-landing/hugo/resources/_gen/
walshit-landing/hugo/cache/
walshit-landing/hugo/.cache/
**/__pycache__/
**/*.py[cod]
