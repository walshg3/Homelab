# qBittorrent + Gluetun stack environment example
# Copy to .env on the containers VM and fill blanks locally.

TZ=America/New_York
PUID=1000
PGID=1000
BASE_PATH=/home/port/stacks/qbittorrent-vpn/data

# TrueNAS/SMB share used for /share inside qBittorrent
SMB_SERVER_IP=192.168.5.251
SMB_SHARE_NAME=storage-share
SMB_USER=
SMB_PASSWORD=

# Host/container ports selected to avoid current conflicts on the containers VM:
# - 8080 is already SABnzbd
# - 8888 is already Dozzle
QBITTORRENT_WEBUI_PORT=8081
QBITTORRENT_PORT=8694

# Gluetun / NordVPN
VPN_SERVICE_PROVIDER=nordvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
SERVER_COUNTRIES=United States
SERVER_REGIONS=
SERVER_CITIES=
SERVER_HOSTNAMES=

# OpenVPN fallback only: NordVPN manual-configuration service credentials.
OPENVPN_USER=
OPENVPN_PASSWORD=
OPENVPN_PROTOCOL=udp
